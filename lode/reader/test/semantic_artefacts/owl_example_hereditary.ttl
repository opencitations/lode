@prefix : <http://example.org/onto#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://example.org/onto#> .

<http://example.org/onto> rdf:type owl:Ontology ;
                           rdfs:label "Test Ontology - Property Inheritance"@en .

#################################################################
#    Object Properties
#################################################################

###  http://example.org/onto#hasCreated
:hasCreated rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :hasRelation ;
            rdfs:label "has created"@en .


###  http://example.org/onto#hasPainted
:hasPainted rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :hasCreated ;
            owl:inverseOf :isPaintedBy ;
            rdfs:label "has painted"@en .


###  http://example.org/onto#hasRelation
:hasRelation rdf:type owl:ObjectProperty ;
             rdfs:domain :Person ;
             rdfs:range :Document ;
             rdfs:label "has relation"@en .


###  http://example.org/onto#isPaintedBy
:isPaintedBy rdf:type owl:ObjectProperty ;
             rdfs:domain :Painting ;
             rdfs:range :Person ;
             rdfs:label "is painted by"@en .


#################################################################
#    Classes
#################################################################

###  http://example.org/onto#Document
:Document rdf:type owl:Class ;
          rdfs:label "Document"@en .


###  http://example.org/onto#Painting
:Painting rdf:type owl:Class ;
          rdfs:subClassOf :Document ;
          rdfs:label "Painting"@en .


###  http://example.org/onto#Person
:Person rdf:type owl:Class ;
        rdfs:label "Person"@en .


